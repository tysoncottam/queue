# --- NextAuth ---
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# --- Google OAuth (sign in + YouTube API for reads/writes) ---
# Console: https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# --- YouTube Data API v3 key (public reads) ---
# Same console: create an API Key, restrict to "YouTube Data API v3"
YOUTUBE_API_KEY=

# --- Database ---
# Local dev:  file:local.db
# Prod: create a DB at https://turso.tech and paste URL + token
TURSO_DATABASE_URL=file:local.db
TURSO_AUTH_TOKEN=

# --- Cron (only needed when deploying) ---
# Random string. The /api/cron/poll GET endpoint requires `Authorization: Bearer <this>`
CRON_SECRET=
